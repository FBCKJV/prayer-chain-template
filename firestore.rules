rules_version = '2';

// Prayer Chain security rules.
// Paste these into: Firebase console → Firestore Database → Rules → Publish.
//
// How invite-only is enforced WITHOUT any server code / billing:
//  - To read or write prayers you must be a "member": have a users/{uid} doc.
//  - You can only CREATE your own users/{uid} doc if the inviteCode you submit
//    matches the secret stored at config/invite — and rules read that doc with
//    get(), so the code itself is never exposed to the client.
//  - config/invite is unreadable/unwritable from the app; edit it only in the
//    Firebase console. Change its `code` field any time to rotate the invite.
//
// Moderators (admins):
//  - A member becomes a moderator only by setting  role: "admin"  on their
//    users/{uid} doc IN THE FIREBASE CONSOLE. It cannot be set from the app,
//    so moderator status can never be self-granted or quietly escalated.
//  - Moderators may delete/mark any prayer or comment and revoke a member's
//    access. All of it is enforced here, not just hidden in the UI.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return isMember()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function validInvite(code) {
      return code == get(/databases/$(database)/documents/config/invite).data.code;
    }

    // Secret invite code — console-only.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Member directory. Every member can see who is in the group (openness by
    // design); role is console-only so nobody can make themselves a moderator.
    match /users/{uid} {
      allow read: if isMember();
      allow create: if signedIn()
        && request.auth.uid == uid
        && validInvite(request.resource.data.inviteCode)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.keys().hasOnly(['name', 'email', 'inviteCode', 'createdAt']);
      // Members may rename themselves; nothing else (including role) is editable.
      allow update: if request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      // A moderator can revoke a member (deleting the doc removes all access).
      allow delete: if isAdmin();
    }

    // Standing weekly prayer list — everyone reads, only moderators edit.
    match /lists/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Prayer requests — one shared feed. No private/DM collections exist.
    match /prayers/{id} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0;
      // The author (or a moderator) can edit/answer/delete a request; any other
      // member may only touch the "I prayed" list or the comment counter.
      allow update: if isMember() && (
        resource.data.uid == request.auth.uid
        || isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy', 'commentCount'])
      );
      allow delete: if isMember() && (resource.data.uid == request.auth.uid || isAdmin());

      // Updates / encouragement on a request.
      match /comments/{cid} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0;
        allow update: if false;
        // Deletable by the comment's author, the prayer's author, or a moderator.
        allow delete: if isMember() && (
          resource.data.uid == request.auth.uid
          || isAdmin()
          || get(/databases/$(database)/documents/prayers/$(id)).data.uid == request.auth.uid
        );
      }
    }
  }
}
